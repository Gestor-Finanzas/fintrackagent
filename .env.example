# =====================================================
# FinTrack — Variables de entorno
# =====================================================
# Copia este fichero a `.env` (local) y rellena los valores reales.
# Para producción (Vercel), añade cada variable en Settings → Environment Variables.
#
# NO committear `.env` con valores reales — está en `.gitignore`.
# =====================================================

# Supabase — REQUERIDAS
# Obtén estos valores en: https://app.supabase.com → tu proyecto → Settings → API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Contact form — OPCIONAL
# Si no se define, el form abrirá el cliente de email del usuario (mailto:).
# Cuando tengas un endpoint real, ponlo aquí.
# REACT_APP_CONTACT_ENDPOINT=https://api.fintrack.app/contact
