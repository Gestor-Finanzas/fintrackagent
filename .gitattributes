# ============================================================
# Line endings — forzar LF en todo el proyecto.
# Git auto-detecta texto vs binario; los ficheros de código
# fuente se normalizan a LF al hacer commit y checkout en todos
# los SOs (Windows, macOS, Linux).
# ============================================================

# Default: texto autodetectado, normalizado a LF
* text=auto eol=lf

# --- Código ---
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf

# --- Markup / estilos / datos ---
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.svg       text eol=lf
*.xml       text eol=lf
*.sql       text eol=lf

# --- Config ---
.editorconfig  text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf
.env.example   text eol=lf
.npmrc         text eol=lf
.nvmrc         text eol=lf

# --- Shell scripts — LF obligatorio (si no, fallan en Linux) ---
*.sh        text eol=lf

# --- Scripts Windows — CRLF obligatorio ---
*.bat       text eol=crlf
*.cmd       text eol=crlf

# ============================================================
# Binary — Git no intenta convertir ni mostrar diff textual
# ============================================================
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.avif      binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.mp4       binary
*.mov       binary
*.webm      binary
*.zip       binary
*.gz        binary
*.tar       binary
